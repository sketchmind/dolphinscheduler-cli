# Copy this file to .env for local development.
#
# Runtime profile keys below are accepted by `dsctl --env-file .env`.
# The same .env file can also be used as DS_LIVE_ADMIN_ENV_FILE for live tests.
DS_VERSION=3.4.1
DS_API_URL=https://dolphinscheduler.example.com/dolphinscheduler
DS_API_TOKEN=replace-with-your-token
DS_API_RETRY_ATTEMPTS=3
DS_API_RETRY_BACKOFF_MS=200

# Live test harness flags are process environment, not dsctl profile keys.
# Example:
# export DSCTL_RUN_LIVE_TESTS=1
# export DSCTL_RUN_LIVE_ADMIN_TESTS=1
# export DS_LIVE_ADMIN_ENV_FILE=$PWD/.env
# export DS_LIVE_QUEUE=default
